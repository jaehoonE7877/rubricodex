{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rubricodex.dev/schemas/v0.1/probe-result.schema.json",
  "title": "Rubricodex Probe Result",
  "type": "object",
  "required": ["schema_version", "artifact_type", "rubricodex_version", "mode", "run_id", "criterion_id", "status", "summary", "read_only", "raw_output_stored"],
  "properties": {
    "schema_version": { "const": "rubricodex.v0.1" },
    "artifact_type": { "const": "rubricodex.probe_result" },
    "rubricodex_version": { "type": "string" },
    "mode": { "enum": ["micro", "quick", "standard", "strict", "audit"] },
    "run_id": { "type": "string", "minLength": 1 },
    "criterion_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["probe_pass", "probe_failure", "probe_error", "probe_skipped"] },
    "summary": { "type": "string", "minLength": 1 },
    "read_only": { "const": true },
    "raw_output_stored": { "const": false },
    "exit_code": { "type": ["integer", "null"] }
  }
}
