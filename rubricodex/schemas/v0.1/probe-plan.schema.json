{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rubricodex.dev/schemas/v0.1/probe-plan.schema.json",
  "title": "Rubricodex Probe Plan",
  "type": "object",
  "required": ["schema_version", "artifact_type", "rubricodex_version", "mode", "run_id", "executor", "parallel", "raw_output_stored", "selected_probes", "skipped_probes"],
  "properties": {
    "schema_version": { "const": "rubricodex.v0.1" },
    "artifact_type": { "const": "rubricodex.probe_plan" },
    "rubricodex_version": { "type": "string" },
    "mode": { "enum": ["micro", "quick", "standard", "strict", "audit"] },
    "run_id": { "type": "string", "minLength": 1 },
    "executor": { "const": "codex-cli-local" },
    "parallel": { "type": "integer", "minimum": 1 },
    "raw_output_stored": { "const": false },
    "selected_probes": { "type": "array" },
    "skipped_probes": { "type": "array" }
  }
}
