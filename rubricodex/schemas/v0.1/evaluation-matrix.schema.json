{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rubricodex.dev/schemas/v0.1/evaluation-matrix.schema.json",
  "title": "Rubricodex Evaluation Matrix",
  "type": "object",
  "required": ["schema_version", "artifact_type", "rubricodex_version", "mode", "method", "criteria"],
  "properties": {
    "schema_version": { "const": "rubricodex.v0.1" },
    "artifact_type": { "const": "rubricodex.evaluation_matrix" },
    "rubricodex_version": { "type": "string" },
    "mode": { "enum": ["micro", "quick", "standard", "strict", "audit"] },
    "method": { "const": "gqe-r-lite" },
    "draft_goal": { "type": "string" },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "claim", "check_question", "evidence_required", "hard_gate", "levels", "retune_hint"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "not": { "enum": [".", ".."] },
            "pattern": "^(?!\\.\\.?$)(?!.*[/\\\\])(?=\\S)(?=.*\\S$)[^\\u0000-\\u001F]+$"
          },
          "name": { "type": "string", "minLength": 1 },
          "claim": { "type": "string", "minLength": 1 },
          "check_question": { "type": "string", "minLength": 1 },
          "evidence_required": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "hard_gate": { "type": "boolean" },
          "levels": {
            "type": "object",
            "required": ["pass", "partial", "fail"],
            "properties": {
              "pass": { "type": "string", "minLength": 1 },
              "partial": { "type": "string", "minLength": 1 },
              "fail": { "type": "string", "minLength": 1 }
            }
          },
          "retune_hint": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
