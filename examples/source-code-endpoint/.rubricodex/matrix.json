      "weight": 0.2,
      "hard_gate": true,
      "observable": "Validation test for blank name",
      "evidence_required": "npm test"
    },
    {
      "id": "data_integrity",
      "description": "Created widgets receive stable string ids and trimmed names.",
      "weight": 0.15,
      "hard_gate": false,
      "observable": "Widget creation response body",
      "evidence_required": "npm test"
    },
    {
      "id": "test_coverage",
      "description": "Health, widget creation, validation failure, and unknown route behavior are covered.",
      "weight": 0.2,
      "hard_gate": false,
      "observable": "Node test suite",
      "evidence_required": "npm test"
    },
    {
      "id": "maintainability",
      "description": "Implementation stays dependency-light and readable.",
      "weight": 0.15,
      "hard_gate": false,
      "observable": "Source review",
      "evidence_required": "Manual review of src/server.js"
